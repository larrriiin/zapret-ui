{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zapret",
  "version": "26.4.5",
  "identifier": "com.alexx.zapret-ui",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Zapret",
        "width": 1000,
        "height": 730,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../version.txt"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "compression": "lzma",
        "languages": [
          "English",
          "Russian"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/larrriiin/zapret-ui/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDQTQ5RUMyNkNERDc4NQpSV1NGMTgwbTdFbktCWElIazBuSSt4c3NySzBmdDRncFZBdXEzSDFCdEMzSUN6RGhaVjdwSEZqaQo="
    }
  }
}
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules
pnpm-lock.yaml
package-lock.json
yarn.lock

# Build artifacts
dist
dist-ssr
/src-tauri/target/
/src-tauri/gen/
/src-tauri/bin/
# version.txt is auto-generated by src-tauri/build.rs from tauri.conf.json
version.txt

# Unused legacy assets (real icons live under src-tauri/icons/)
/logo.ico
/logo.png

# Local files & Binaries.
# Everything under binaries/ is either downloaded from the Flowseal upstream at
# first launch (*.bat, lists/, bin/, utils/) or is user-editable runtime state
# (*.enabled, user lists). Keep a .gitkeep so the directory exists on clone —
# `ensure_binaries_present` creates it otherwise, but tooling that expects the
# folder on fresh checkouts is simpler this way.
*.local
.env
.env.*
*.backup
binaries/*
!binaries/.gitkeep

# Editor & OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Tauri specific
src-tauri/zapret-ui-manifest.rc
src-tauri/zapret-ui.manifest
~/.tauri/zapret-ui.key
/~
